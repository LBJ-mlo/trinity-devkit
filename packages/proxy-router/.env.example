# Trinity Router 配置文件
# 复制此文件为 .env，填入你的 API Key

# ─── 必填 ──────────────────────────────────────
# DeepSeek API Key（聊天、分析、分类器都依赖它）
DEEPSEEK_API_KEY=sk-你的DeepSeek密钥

# ─── 可选：多模型扩展 ──────────────────────────
# GLM-4 API Key（编码任务用，不填则编码也走 DeepSeek）
# GLM_API_KEY=你的GLM密钥

# Claude API Key（代码审查等专用，不填则不启用 Claude 路由）
# ANTHROPIC_API_KEY=sk-ant-你的Claude密钥

# ─── 可选：端口和地址 ──────────────────────────
# PORT=8888
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic/v1
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
